<PsychoPy2experiment version="1.80.03" encoding="utf-8">
  <Settings>
    <Param name="Show mouse" val="False" valType="bool" updates="None"/>
    <Param name="Data filename" val="'data/%s_%s_%s' %(expInfo['participant'], expName, expInfo['date'])" valType="code" updates="None"/>
    <Param name="Monitor" val="testMonitor" valType="str" updates="None"/>
    <Param name="Enable Escape" val="True" valType="bool" updates="None"/>
    <Param name="color" val="$[0,0,0]" valType="str" updates="None"/>
    <Param name="Window size (pixels)" val="[1600, 900]" valType="code" updates="None"/>
    <Param name="Full-screen window" val="True" valType="bool" updates="None"/>
    <Param name="colorSpace" val="rgb" valType="str" updates="None"/>
    <Param name="Experiment info" val="{u'session': u'001', u'participant': u''}" valType="code" updates="None"/>
    <Param name="Save csv file" val="False" valType="bool" updates="None"/>
    <Param name="Show info dlg" val="True" valType="bool" updates="None"/>
    <Param name="Save wide csv file" val="True" valType="bool" updates="None"/>
    <Param name="Save psydat file" val="True" valType="bool" updates="None"/>
    <Param name="expName" val="test2017_7_spatial" valType="str" updates="None"/>
    <Param name="logging level" val="exp" valType="code" updates="None"/>
    <Param name="blendMode" val="avg" valType="str" updates="None"/>
    <Param name="Save excel file" val="False" valType="bool" updates="None"/>
    <Param name="Units" val="use prefs" valType="str" updates="None"/>
    <Param name="Save log file" val="False" valType="bool" updates="None"/>
    <Param name="Screen" val="1" valType="num" updates="None"/>
  </Settings>
  <Routines>
    <Routine name="answer">
      <CodeComponent name="code">
        <Param name="Begin Experiment" val="" valType="extendedCode" updates="constant"/>
        <Param name="name" val="code" valType="code" updates="None"/>
        <Param name="Each Frame" val="#b = mouse.getPressed()&#10;#if b[0] == 1:&#10;#    xp = mouse.getPos()[0]&#10;#    yp = mouse.getPos()[1]&#10;#if xposi[0]-0.1 &lt; any(np.array(mouse.x)) &lt; xposi[0]+0.1:# and any(mouse.y) == yposi[0]:&#10;#    op1 = 1&#10;&#10;if mouse.isPressedIn(pos1):&#10;    op1 = 1&#10;    test[0] = 1&#10;if mouse.isPressedIn(pos2):&#10;    op2 = 1&#10;    test[1] = 2&#10;if mouse.isPressedIn(pos3):&#10;    op3 = 1&#10;    test[2] = 3&#10;if mouse.isPressedIn(pos4):&#10;    op4 = 1&#10;    test[3] = 4&#10;if mouse.isPressedIn(pos5):&#10;    op5 = 1&#10;    test[4] = 5&#10;if mouse.isPressedIn(pos6):&#10;    op6 = 1&#10;    test[5] = 6&#10;if mouse.isPressedIn(pos7):&#10;    op7 = 1&#10;    test[6] = 7&#10;if mouse.isPressedIn(pos8):&#10;    op8 = 1&#10;    test[7] = 8&#10;if mouse.isPressedIn(pos9):&#10;    op9 = 1&#10;    test[8] = 9&#10;if mouse.isPressedIn(pos10):&#10;    op10 = 1&#10;    test[9] = 10&#10;if mouse.isPressedIn(pos11):&#10;    op11 = 1&#10;    test[10] = 11&#10;if mouse.isPressedIn(pos12):&#10;    op12 = 1&#10;    test[11] = 12&#10;if mouse.isPressedIn(pos13):&#10;    op13 = 1&#10;    test[12] = 13&#10;if mouse.isPressedIn(pos14):&#10;    op14 = 1&#10;    test[13] = 14&#10;if mouse.isPressedIn(pos15):&#10;    op15 = 1&#10;    test[14] = 15&#10;if mouse.isPressedIn(pos16):&#10;    op16 = 1&#10;    test[15] = 16&#10;" valType="extendedCode" updates="constant"/>
        <Param name="Begin Routine" val="if trials_3.thisRepN &gt; 1:&#10;    dur = dur + (trials_3.thisRepN-1)&#10;" valType="extendedCode" updates="constant"/>
        <Param name="End Routine" val="#xp,indx = np.unique(mouse.x,return_index=True)&#10;#yp,indy = np.unique(mouse.y,return_index=True)&#10;#xp = np.array(mouse.x)[np.sort(indx)]&#10;#yp = np.array(mouse.y)[np.sort(indy)]&#10;#testx1 = xposi[seq[0:m]]-0.1 &lt; xp[0:m]&#10;#testx2 = xp[0:m]&lt; xposi[seq[0:m]]+0.1&#10;#testy1 = yposi[seq[0:m]]-0.1 &lt; yp[0:m]&#10;#testy2 = yp[0:m]&lt; yposi[seq[0:m]]+0.1&#10;#if all(testx1) and all(testx2) and all(testy1) and all(testy2):&#10;#    correct = 1&#10;seq = seq + 1&#10;if all(np.sort(seq[0:m])[::-1] == np.sort(test)[::-1][0:m]):&#10;    correct[trials_2.thisN] = 1&#10;else: &#10;    correct[trials_2.thisN] = 0&#10;seq = seq-1&#10;point = np.sort(test)[::-1][0:m]&#10;trials.addData('x_axis',xposi[seq[0:m]])&#10;trials.addData('y_axis',yposi[seq[0:m]])&#10;trials.addData('point',point)&#10;trials.addData('order',seq[0:m]+1)&#10;trials.addData('correct',correct)&#10;&#10;m = 0&#10;op1 = 0&#10;op2 = 0&#10;op3 = 0&#10;op4 = 0&#10;op5 = 0&#10;op6 = 0&#10;op7 = 0&#10;op8 = 0&#10;op9 = 0&#10;op10 = 0&#10;op11 = 0&#10;op12 = 0&#10;op13 = 0&#10;op14 = 0&#10;op15 = 0&#10;op16 = 0&#10;#xp = 0&#10;#yp = 0&#10;#indx = 0&#10;#indy = 0&#10;#correct = np.zeros(2)&#10;point = 0&#10;test = np.zeros(16)&#10;dur = 3&#10;np.random.shuffle(seq)" valType="extendedCode" updates="constant"/>
        <Param name="End Experiment" val="" valType="extendedCode" updates="constant"/>
      </CodeComponent>
      <MouseComponent name="mouse">
        <Param name="name" val="mouse" valType="code" updates="None"/>
